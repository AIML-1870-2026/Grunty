PORT=3000

# Provider: 'anthropic' or 'openai'
SWITCHBOARD_PROVIDER=anthropic

# API key for the chosen provider
SWITCHBOARD_API_KEY=your_key_here

# Model to use
# Anthropic options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenAI options: gpt-4o | gpt-4o-mini | gpt-4-turbo
SWITCHBOARD_MODEL=claude-haiku-4-5-20251001

# Path to product JSON files (relative to project root)
PRODUCTS_DIR=./products
